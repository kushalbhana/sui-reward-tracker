# ============================================
# Docker Compose environment variables
# Copy this file to .env and fill in values
# ============================================

# MongoDB credentials  
MONGO_USER=admin
MONGO_PASSWORD=password

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_to_a_random_secret

# OAuth providers
GOOGLE_ID=your_google_client_id
GOOGLE_SECRET=your_google_client_secret
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# Public wallet addresses
NEXT_PUBLIC_SUI_WALLET=0x...
NEXT_PUBLIC_SOLANA_WALLET=...

# Indexer config
RPC_URLS=https://fullnode.mainnet.sui.io:443
PAGE_SIZE=50

# PaymentKit configuration
# Set to "testnet" for development — uses a nominal 0.01 SUI amount (no real money)
# Set to "mainnet" for production
NEXT_PUBLIC_PAYMENT_KIT_NETWORK=mainnet

# Server-side RPC for SUI payment verification
# Mainnet: https://fullnode.mainnet.sui.io:443
# Testnet: https://fullnode.testnet.sui.io:443
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Server-side RPC for SOL payment verification
# Mainnet (production): https://api.mainnet-beta.solana.com
# Devnet  (testing):    https://api.devnet.solana.com
# If omitted, the value is derived from NEXT_PUBLIC_PAYMENT_KIT_NETWORK automatically.
# For production use a private RPC (Helius / QuickNode / Alchemy) to avoid rate limits.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Subscription price in USD — server fetches live SUI price and converts
SUBSCRIPTION_PRICE_USD=25
